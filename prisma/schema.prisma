generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  botAvatar     String?   // avatar bot reminder, null = pakai default icon lonceng
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  rooms    Room[]
  messages Message[]

  @@map("users")
}

model Room {
  id          String   @id @default(cuid())
  name        String
  icon        String   @default("💬")
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@map("rooms")
}

model Message {
  id              String    @id @default(cuid())
  text            String
  type            MessageType @default(TEXT)
  isDone          Boolean   @default(false)  // pesan ditandai selesai
  isPinned        Boolean   @default(false)  // pesan di-pin
  isBot           Boolean   @default(false)  // true = pesan dari sistem reminder
  remindAt        DateTime?                  // waktu reminder diset user
  remindSnoozeAt  DateTime?                  // waktu baru setelah ditunda
  isRemindDone    Boolean   @default(false)  // reminder sudah di-resolve
  sourceMessageId String? @unique             // relasi ke pesan asli yang di-remind (unique mencegah duplikat bot reminder)
  userId          String
  roomId          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  editedAt        DateTime?

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  room          Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sourceMessage Message?  @relation("ReminderSource", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  reminders     Message[] @relation("ReminderSource")
  checklistItems ChecklistItem[]

  @@index([roomId, createdAt(sort: Desc)])
  @@index([remindAt])
  @@map("messages")
}

model ChecklistItem {
  id        String   @id @default(cuid())
  text      String
  isDone    Boolean  @default(false)
  position  Int
  messageId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, position])
  @@map("checklist_items")
}

enum MessageType {
  TEXT
  CHECKLIST
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
